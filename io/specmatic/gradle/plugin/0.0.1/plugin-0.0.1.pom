      <name>MIT</name>
      <url>https://opensource.org/license/mit</url>
    </license>
  </licenses>
  <developers>
    <developer>
      <id>specmaticBuilders</id>
      <name>Specmatic Builders</name>
      <email>info@specmatic.io</email>
    </developer>
  </developers>
  <scm>
    <connection>https://github.com/znsio/specmatic-gradle-plugin</connection>
    <url>https://github.com/znsio/specmatic-gradle-plugin</url>
  </scm>
  <dependencies>
    <dependency>
      <groupId>com.github.jk1</groupId>
      <artifactId>gradle-license-report</artifactId>
      <version>2.9</version>
      <scope>runtime</scope>
    </dependency>
    <dependency>
      <groupId>com.adarshr</groupId>
      <artifactId>gradle-test-logger-plugin</artifactId>
      <version>4.0.0</version>
      <scope>runtime</scope>
    </dependency>
