  <!-- do_not_remove: published-with-gradle-metadata -->
  <modelVersion>4.0.0</modelVersion>
  <groupId>io.specmatic.gradle</groupId>
  <artifactId>plugin</artifactId>
  <version>0.0.1</version>
  <name>Specmatic Gradle Plugin</name>
